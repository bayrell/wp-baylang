namespace Runtime.Test;

use Runtime.DateTime;
use Runtime.Unit.AssertHelper;
use Runtime.Unit.Test;


class DateTest
{
	/**
	 * Padding
	 */
	string pad2(int value)
	{
		if (value < 10) return "0" ~ value;
		return value;
	}
	
	
	@Test{}
	void checkCopyDate()
	{
		DateTime date = new DateTime{
			"y": 2026, "m": 3, "d": 16,
			"h": 0, "i": 0, "s": 0, "o": 5,
		};
		
		for (int i=0; i<24; i++)
		{
			DateTime copy_date = date.copy({ "h": i });
			string correct_date = "2026-03-16 " ~ this.pad2(copy_date.h) ~ ":00:00";
			AssertHelper::equalValue(copy_date.format(), correct_date);
			AssertHelper::equalValue(copy_date.o, date.o);
		}
	}
	
	
	@Test{}
	void checkDayOfWeek()
	{
		DateTime date = new DateTime{
			"y": 2026, "m": 3, "d": 16,
			"h": 0, "i": 0, "s": 0, "o": 5,
		};
		
		for (int i=0; i<24; i++)
		{
			DateTime copy_date = date.copy({ "h": i });
			int day = copy_date.getDayOfWeek();
			AssertHelper::equalValue(day, 1, "Hour: " ~ i);
		}
	}
	
	/*
	@Test{}
	void checkDayOfWeek2()
	{
		DateTime date = new DateTime{
			"y": 2026, "m": 3, "d": 16,
			"h": 19, "i": 0, "s": 0, "o": 5,
		};
		
		int day = date.getDayOfWeek();
		AssertHelper::equalValue(day, 1, "Hour: " ~ date.h);
	}*/
}