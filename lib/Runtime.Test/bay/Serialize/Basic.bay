namespace Runtime.Test.Serialize;

use Runtime.Serializer;
use Runtime.Serializer.BaseType;
use Runtime.Serializer.IntegerType;
use Runtime.Serializer.MapType;
use Runtime.Serializer.StringType;
use Runtime.Serializer.TypeError;
use Runtime.Serializer.VectorType;
use Runtime.Unit.AssertHelper;
use Runtime.Unit.Test;


class Basic
{	
	@Test{}
	void checkString1()
	{
		string api_value = "User";
		string correct_value = "User";
		
		Vector errors = [];
		BaseType rule = new StringType();
		string new_value = rule.filter(api_value, errors);
		
		errors = TypeError::getMessages(errors);
		AssertHelper::equalValue(errors.count(), 0, rs::join(", ", errors));
		AssertHelper::equalValue(correct_value, new_value);
	}
	
	
	@Test{}
	void checkString2()
	{
		int api_value = 1;
		string correct_value = "1";
		
		Vector errors = [];
		BaseType rule = new StringType();
		string new_value = rule.filter(api_value, errors);
		
		errors = TypeError::getMessages(errors);
		AssertHelper::equalValue(errors.count(), 0, rs::join(", ", errors));
		AssertHelper::equalValue(correct_value, new_value);
	}
	
	
	@Test{}
	void checkString3()
	{
		int api_value = 1;
		string correct_value = "";
		
		Vector errors = [];
		BaseType rule = new StringType({"convert": false});
		string new_value = rule.filter(api_value, errors);
		
		AssertHelper::equalValue(errors.count(), 1, "Should be errors");
		AssertHelper::equalValue(correct_value, new_value);
	}
	
	
	@Test{}
	void checkInteger1()
	{
		int api_value = 1;
		int correct_value = 1;
		
		Vector errors = [];
		BaseType rule = new IntegerType();
		string new_value = rule.filter(api_value, errors);
		
		errors = TypeError::getMessages(errors);
		AssertHelper::equalValue(errors.count(), 0, rs::join(", ", errors));
		AssertHelper::equalValue(correct_value, new_value);
	}
	
	
	@Test{}
	void checkInteger2()
	{
		int api_value = "1";
		int correct_value = 1;
		
		Vector errors = [];
		BaseType rule = new IntegerType();
		string new_value = rule.filter(api_value, errors);
		
		errors = TypeError::getMessages(errors);
		AssertHelper::equalValue(errors.count(), 0, rs::join(", ", errors));
		AssertHelper::equalValue(correct_value, new_value);
	}
	
	
	@Test{}
	void checkInteger3()
	{
		int api_value = [];
		int correct_value = 1;
		
		Vector errors = [];
		BaseType rule = new IntegerType();
		string new_value = rule.filter(api_value, errors);
		
		AssertHelper::equalValue(errors.count(), 1, "Should be errors");
	}
	
	
	@Test{}
	void checkMap1()
	{
		Map api_value = {
			"name": "User"
		};
		Map correct_value = {
			"name": "User"
		};
		
		BaseType rule = new MapType(new StringType());
		Vector errors = [];
		Map new_value = rule.filter(api_value, errors);
		
		errors = TypeError::getMessages(errors);
		AssertHelper::equalValue(errors.count(), 0, rs::join(", ", errors));
		AssertHelper::equalValue(correct_value, new_value);
	}
	
	
	@Test{}
	void checkMap2()
	{
		Map api_value = {
			"name": 1
		};
		Map correct_value = {
			"name": "1"
		};
		
		Vector errors = [];
		BaseType rule = new MapType(new StringType());
		Map new_value = rule.filter(api_value, errors);
		
		errors = TypeError::getMessages(errors);
		AssertHelper::equalValue(errors.count(), 0, rs::join(", ", errors));
		AssertHelper::equalValue(correct_value, new_value);
	}
	
	
	@Test{}
	void checkMap3()
	{
		Map api_value = {
			"name": "User",
			"fruits": ["apple", "banana", "cherry", "grape", "orange", "watermelon"],
		};
		Map correct_value = {
			"name": "User",
			"fruits": ["apple", "banana", "cherry", "grape", "orange", "watermelon"],
		};
		
		BaseType rule = new MapType{
			"name": new StringType(),
			"fruits": new VectorType(new StringType()),
		};
		Vector errors = [];
		Map new_value = rule.filter(api_value, errors);
		
		errors = TypeError::getMessages(errors);
		AssertHelper::equalValue(errors.count(), 0, rs::join(", ", errors));
		AssertHelper::equalValue(correct_value, new_value);
	}
	
	
	@Test{}
	void checkVector1()
	{
		Vector api_value = ["a", "b", "c"];
		Vector correct_value = ["a", "b", "c"];
		
		Vector errors = [];
		BaseType rule = new VectorType(new StringType());
		string new_value = rule.filter(api_value, errors);
		
		errors = TypeError::getMessages(errors);
		AssertHelper::equalValue(errors.count(), 0, rs::join(", ", errors));
		AssertHelper::equalValue(correct_value, new_value);
	}
	
	
	@Test{}
	void checkVector2()
	{
		Vector api_value = [1];
		Vector correct_value = ["1"];
		
		Vector errors = [];
		BaseType rule = new VectorType(new StringType());
		string new_value = rule.filter(api_value, errors);
		
		errors = TypeError::getMessages(errors);
		AssertHelper::equalValue(errors.count(), 0, rs::join(", ", errors));
		AssertHelper::equalValue(correct_value, new_value);
	}
}